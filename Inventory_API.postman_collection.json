          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"product\": \"{{product_id}}\",\n  \"quantity\": 5\n}"
        },
        "url": {
          "raw": "http://localhost:3000/api/reservation",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "reservation"]
        }
      }
    },
    {
      "name": "Sold (Hoàn tất bán hàng)",
      "request": {
        "method": "POST",
        "header": [
